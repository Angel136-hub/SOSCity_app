<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_handle" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Titolo + badge stato -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/detailTicketRef"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intervento"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Dettaglio intervento"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/detailStatoBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_pianificato"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:text="PIANIFICATO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- Sezione info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMAZIONI"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Ticket ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ticket ID"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detailTicketId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Team ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Team"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detailTeamId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="—"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Date riga -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_info"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inizio"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/detailDataInizio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chip_info"
                    android:padding="14dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fine"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/detailDataFine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="In corso"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Creato il -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Creato il"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detailDataCreazione"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Note operatore -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTE OPERATIVE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/detailNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_info"
                android:padding="14dp"
                android:text="Nessuna nota"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="20dp" />

            <!-- Separatore azioni -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#C8E6C9"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AZIONI RAPIDE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Campo nota -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutNotaDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Aggiungi nota (opzionale)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                android:textColorHint="#9E9E9E"
                android:visibility="gone">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editNotaDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="1"
                    android:maxLines="3"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bottoni -->
            <LinearLayout
                android:id="@+id/layoutAzioniDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAvviaDetail"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="▶  Avvia"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="@color/primary_light"
                    app:cornerRadius="12dp"
                    app:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompletaDetail"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="✓  Completa"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="12dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <!-- Messaggio completato -->
            <TextView
                android:id="@+id/detailCompletato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_in_corso"
                android:gravity="center"
                android:padding="12dp"
                android:text="Intervento completato"
                android:textColor="#1B5E20"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
