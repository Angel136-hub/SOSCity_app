<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ══════════ HEADER blu arrotondato con saluto (stesso stile del tecnico) ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_greeting_section"
        android:elevation="6dp"
        android:paddingBottom="24dp">

        <View android:layout_width="match_parent" android:layout_height="20dp" />

        <!-- Riga logout, allineata a destra -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <FrameLayout
                android:id="@+id/btnImpostazioni"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_stat_card"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_pulsante_impostazioni"
                android:foreground="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_settings"
                    android:importantForAccessibility="no"
                    app:tint="@color/primary" />
            </FrameLayout>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_logout_button"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_pulsante_logout">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_logout"
                    android:importantForAccessibility="no"
                    app:tint="@color/error" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Esci"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:importantForAccessibility="no"
                    android:textColor="@color/error" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textSaluto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Benvenuto!"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="26sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rendi la tua città un posto migliore"
            android:textColor="#E0F2F1"
            android:textSize="14sp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />
    </LinearLayout>

    <!-- ══════════ NOTIFICHE, mostrate direttamente in Home: non piu' una card
         che rimanda a un'altra schermata, ma la lista reale (stesso
         ViewModel/adapter di NotificheFragment) ══════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notifiche"
        android:textStyle="bold"
        android:textColor="#455A64"
        android:textSize="14sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"/>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshNotificheHome"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNotificheHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false" />

            <ProgressBar
                android:id="@+id/progressNotificheHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/emptyStateNotificheHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="32dp"
                android:text="Non hai ancora ricevuto notifiche"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>