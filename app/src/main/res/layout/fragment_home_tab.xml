<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══════════ HEADER VERDE con saluto ══════════ -->
    <LinearLayout
        android:id="@+id/greetingSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_greeting_section"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent">

        <View android:layout_width="match_parent" android:layout_height="28dp" />

        <!-- Riga icone: impostazioni + logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <!-- Bottone Impostazioni -->
            <FrameLayout
                android:id="@+id/btnImpostazioni"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_stat_card"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_pulsante_impostazioni"
                android:foreground="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_settings"
                    android:importantForAccessibility="no"
                    app:tint="@color/primary" />
            </FrameLayout>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <!-- Logout compatto -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_logout_button"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_pulsante_logout">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_logout"
                    android:importantForAccessibility="no"
                    app:tint="@color/error" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Esci"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:importantForAccessibility="no"
                    android:textColor="@color/error" />
            </LinearLayout>
        </LinearLayout>

        <!-- Saluto + contatore -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/textSaluto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Buongiorno, Marco!"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDescrizioneGiornata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Oggi hai 4 interventi in programma"
                android:textSize="14sp"
                android:textColor="@color/primary_light_text" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════ CONTENUTO SCROLLABILE ══════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/greetingSection"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- ── PROSSIMO INTERVENTO ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.1"
                android:text="PROSSIMO INTERVENTO"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Card prossimo intervento -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProssimoIntervento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Stato badge + data -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:id="@+id/cardStatoBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_pianificato"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="IN_CORSO"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView
                            android:id="@+id/cardDataInizio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10/06 09:00"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <!-- Ticket ref -->
                    <TextView
                        android:id="@+id/cardTicketRef"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ticket #AB1234CD"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <!-- Categoria ticket -->
                    <TextView
                        android:id="@+id/cardCategoria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Categoria: —"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Urgenza / priorità -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="54dp"
                            android:layout_height="match_parent"
                            android:text="Urgenza: "
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/cardPriorita"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Note -->
                    <TextView
                        android:id="@+id/cardNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_info"
                        android:padding="12dp"
                        android:layout_marginTop="12dp"
                        android:text="Nessuna nota operative"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:visibility="gone" />

                    <!-- Bottone apri dettaglio -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApriDettaglio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="Vedi dettaglio completo →"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Placeholder se nessun intervento -->
            <LinearLayout
                android:id="@+id/layoutNessunProssimo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_next_intervention_card"
                android:padding="32dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Nessun intervento in programma"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- ── RIEPILOGO RAPIDO ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.1"
                android:text="RIEPILOGO RAPIDO"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Completati -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_summary_card"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/countCompletati"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/stato_completato"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Completati"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Mancanti -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_summary_card"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/countMancanti"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/stato_pianificato"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Da fare"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Sospesi -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_summary_card"
                    android:padding="16dp"
                    android:layout_marginStart="6dp"
                    android:elevation="2dp">
                    <TextView
                        android:id="@+id/countSospesi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/stato_sospeso"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sospesi"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <!-- Loading overlay -->
            <ProgressBar
                android:id="@+id/progressHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
