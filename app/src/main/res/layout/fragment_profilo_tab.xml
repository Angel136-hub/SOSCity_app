<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header verde profilo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_greeting_section"
            android:paddingTop="48dp"
            android:paddingBottom="36px"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_avatar_circle">
                <TextView
                    android:id="@+id/profiloInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="T"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </FrameLayout>

            <TextView
                android:id="@+id/profiloNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Nome Cognome"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/profiloUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@username"
                android:textSize="14sp"
                android:textColor="@color/primary_light_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/surface"
                android:letterSpacing="0.08"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="@string/profilo_ruolo_tecnico"
                android:textColor="@color/primary_light_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:importantForAccessibility="no" />

            <View android:layout_width="match_parent" android:layout_height="8dp" />
        </LinearLayout>

        <!-- Dettagli -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATI PERSONALI"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:importantForAccessibility="no"
                    android:text="" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/profiloEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="—" android:textSize="14sp" android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Disponibilità -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:importantForAccessibility="no"
                    android:text="" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Disponibilità" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/profiloDisponibilita" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="—" android:textSize="14sp" android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SQUADRA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Team -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:importantForAccessibility="no"
                    android:text="" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Team assegnato" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/profiloTeam" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="—" android:textSize="14sp" android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Competenze -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_info"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:importantForAccessibility="no"
                    android:text="" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Competenze" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/profiloCompetenze" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="—" android:textSize="14sp" android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogoutProfilo"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/logout_titolo"
                android:contentDescription="@string/cd_pulsante_logout"
                android:textColor="@color/error"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#FDECEA"
                app:cornerRadius="14dp"
                app:elevation="0dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>